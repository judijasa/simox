#!/bin/bash

set -euo pipefail

if [[ ! -v IN_NIX_SHELL ]]; then
    source /etc/environment
fi

SCRIPT="${1%%:*}"
SCRIPT_NAME=$(basename "$SCRIPT" .php)
DIR_PREFIX=$(dirname "$SCRIPT" | tr '/' '_')
LOG_FILE="${SIMO_LOG_PATH}/${DIR_PREFIX}_${SCRIPT_NAME}.log"

touch -a "$LOG_FILE"

if [ -t 1 ]; then
    exec > >(tee -a "$LOG_FILE") 2>&1
else
    exec >> "$LOG_FILE" 2>&1
fi

php "$(dirname "$0")/phprun.php" "$1"
