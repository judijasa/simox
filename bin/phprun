#!/bin/bash

set -euo pipefail

if [[ ! -v IN_NIX_SHELL ]]; then
    source /etc/environment
fi

parent=$(ps -o comm= -p "$PPID")
if [[ "$parent" == "cron" || "$parent" == "crond" ]]; then
    cd "$SIMO_REPO_PATH"
elif [[ "$PWD" != "$SIMO_REPO_PATH" ]]; then
    echo "This command must be executed from the repository's root directory." >&2
    exit 1
fi

ARG="${1:-}"

if [[ -z "$ARG" || "$ARG" != *:* ]]; then
    echo "Usage: phprun 'path/to/script.php:my_agent(args)'" >&2
    exit 1
fi

SCRIPT="${ARG%%:*}"
SCRIPT_NAME=$(basename "$SCRIPT" .php)
DIR_PREFIX=$(dirname "$SCRIPT" | tr '/' '_')
LOG_FILE="${SIMO_LOG_PATH}/${DIR_PREFIX}_${SCRIPT_NAME}.log"

touch -a "$LOG_FILE"

if [ -t 1 ]; then
    exec > >(tee -a "$LOG_FILE") 2>&1
else
    exec >> "$LOG_FILE" 2>&1
fi

php "$SIMO_REPO_PATH/src/utils/phprun.php" "$ARG"
