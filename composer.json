{
  "extra": {
    "readme": ["jakoch/phantomjs-installer is a jerome-breton/casperjs-installer dependency.",
      "I have fixed its version to allows predictible shimming."
    ]
  },
  "require": {
    "sunra/php-simple-html-dom-parser": "1.5.2",
    "jerome-breton/casperjs-installer": "dev-master",
    "jakoch/phantomjs-installer": "3.0.3",
    "phpcasperjs/phpcasperjs": "^1.3",
    "phpmailer/phpmailer": "^6.5"
  },
  "scripts": {
    "post-install-cmd": [
      "CasperJsInstaller\\Installer::install"
    ],
    "post-update-cmd": [
      "CasperJsInstaller\\Installer::install"
    ]
  },
  "autoload": {
    "psr-4":{
      "Utils\\": "src/utils/"
    }
  }
}
