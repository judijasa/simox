# etc/cron.d/simo-orchestrator
# To be deployed at /etc/cron.d/simo-orchestrator
# Run your custom 5-minute jobs safely isolated
*/5 * * * * root run-parts /etc/simo-cron.5min

# Run your custom hourly jobs safely isolated
0 * * * * root run-parts /etc/simo-cron.hourly

# Run your custom monthly jobs safely isolated
0 0 1 * * root run-parts /etc/simo-cron.monthly
